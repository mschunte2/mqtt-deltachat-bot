# mqtt-bot — environment template.
# Copy to .env/env and edit, OR keep alongside other env files in .env/.
# start-mqtt-bot.sh sources .env/env at startup.

# --- Bot identity ---------------------------------------------------------
BOT_NAME=mqtt-bot
ALLOWED_CHATS=                      # comma-separated chat IDs; bot replies to /id with the current chat ID

# --- MQTT broker ----------------------------------------------------------
MQTT_HOST=127.0.0.1
MQTT_PORT=1883
MQTT_USER=mqtt-bot
MQTT_PASS=                          # set after running setup-mosquitto.sh
MQTT_CLIENT_ID=mqtt-bot
MQTT_KEEPALIVE=30

# --- Engine ---------------------------------------------------------------
DEVICES_FILE=./devices.json
LOG_LEVEL=info                      # debug | info | warning | error
HELP_MESSAGE=                       # optional free-text appended to /help; leave empty for auto-generated only

# --- History (SQLite time series) -----------------------------------------
RETENTION_DAYS=0                    # 0 = keep forever; >0 prunes daily

# --- App push pipeline ----------------------------------------------------
PUBLISH_INTERVAL_S=300              # 60..900; how often Publisher broadcasts
                                    # the ground-truth snapshot to apps when
                                    # idle (state edges + refresh-button push
                                    # immediately regardless of this).
